{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Renderer",
            "type": "chrome",
            "request": "attach",
            "port": 9876,
            "sourceMaps": true,
            "urlFilter": "http://localhost:4200*",
            "timeout": 20000,
            "trace": true,
            "preLaunchTask": "Build.Renderer",
        },
        {
            "name": "Main",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
            "trace": true,
            "runtimeArgs": [
                "--serve",
                ".",
                "--remote-debugging-port=9876"
            ],
            "windows": {
                "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
            },
            "outFiles": ["${workspaceFolder}/app/**/*.js"],
            "sourceMaps": true,
            "preLaunchTask": "Build.Main"
        },
        {
            "name": "Run Current Angular Test File",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/node_modules/@angular/cli/bin/ng",
            "args": [
                "test",
                "--include",
                "**/${fileBasename}",
                "--debug",
            ],
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run Current Main Process Test File",
            "autoAttachChildProcesses": true,
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "program": "${workspaceRoot}/node_modules/vitest/vitest.mjs",
            "args": ["run", "${relativeFile}"],
            "smartStep": true,
            "sourceMaps": true,
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Test All Main Process Files",
            "autoAttachChildProcesses": true,
            "runtimeExecutable": "npm",
            "args": ["run", "electron:test"],
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Test All Angular Files",
            "runtimeExecutable": "npm",
            "args": ["run", "angular-test"],
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Application Debug",
            "configurations": [ "Main", "Renderer" ]
        }
    ]
}