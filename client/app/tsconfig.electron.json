{
  "compilerOptions": {
    "strict": true,
    "composite": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "commonjs",
    "target": "es2022",
    "types": [
      "node"
    ]
  },
  "include": [
    "**/*.ts",
    "../src/app/immerse/subtitle-interface.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.spec.ts"
  ]
}
