{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["app/shared/*"],
      "@app/*": ["app/*"],
      "@assets/*": ["assets/*"],
      "@env/*": ["environments/*"]
    },
    "esModuleInterop": true,
    "outDir": "../out-tsc/spec",
    "typeRoots": ["../node_modules/@types", "../node_modules"],
    "types": [
      "vitest/globals",
      "node"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.spec.ts",
    "**/*.d.ts",
    "../app/ipc/ipc-api.d.ts"
  ],
  "exclude": [
    "dist",
    "release",
    "node_modules"
  ]
}
